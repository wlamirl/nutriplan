{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],

    /* Strict */
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,

    /* Output */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,

    /* Interop */
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
